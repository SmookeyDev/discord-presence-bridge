{
	"name": "@discord-rpc/extension",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build && wxt build -b firefox",
		"build:chrome": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"zip:all": "wxt zip && wxt zip -b firefox",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf .output .wxt"
	},
	"dependencies": {
		"@discord-rpc/shared-types": "workspace:*"
	},
	"devDependencies": {
		"@types/chrome": "^0.0.287",
		"typescript": "^5.8.2",
		"wxt": "^0.19.0"
	}
}
