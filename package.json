{
	"name": "discord-presence-bridge",
	"version": "0.4.0",
	"private": true,
	"type": "module",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"build": "turbo run build",
		"build:server": "turbo run build --filter=@discord-rpc/server",
		"build:extension": "turbo run build --filter=@discord-rpc/extension",
		"dev": "turbo run dev",
		"dev:server": "turbo run dev --filter=@discord-rpc/server",
		"dev:extension": "turbo run dev --filter=@discord-rpc/extension",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"clean": "turbo run clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.3.0",
		"typescript": "^5.8.2"
	},
	"packageManager": "bun@1.1.42",
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SmookeyDev/discord-presence-bridge.git"
	},
	"license": "GPL-3.0",
	"bugs": {
		"url": "https://github.com/SmookeyDev/discord-presence-bridge/issues"
	},
	"homepage": "https://github.com/SmookeyDev/discord-presence-bridge#readme"
}
